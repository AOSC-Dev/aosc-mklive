insmod part_gpt
insmod part_msdos
insmod all_video
insmod gzio
insmod iso9660
insmod phymem
insmod pause
phymem
terminal_input console

set gfxmode=1024x768
set gfxpayload=keep
set menu_color_normal=white/black

set pager=1
set timeout=30

set retro=@@RETRO@@
set nogui=0
set nocli=0

# Behavior difference between mainline LiveKit and Retro LiveKit
if [ "x$retro" = "x1" ] ; then
	# lower memory requirement (and no GUI environment)
	set memreq=78
	# default option
	set default=livekit_cli
	# no gfxterm (some old retro graphics cards won't play well with gfxterm)
	terminal_output console
	# Different accent color
	set menu_color_highlight=light-red/black
	set cli_title="LiveKit"
	set nogui=1
else
	# basic memory requirement for GUI environment
	set memreq=2048
	set default=livekit_gui
	# With gfxterm
	insmod gfxterm
	terminal_output gfxterm
	# load Unifont
	loadfont /boot/grub/fonts/unicode.pf2
	# Blue accent color
	set menu_color_highlight=light-blue/black
	set cli_title="LiveKit (command line only)"
fi

function err_lowmem {
	if [ "x$retro" = "x1" ] ; then
		echo "Your system currently have $total_mem_rounded MiB of memory, but at least $memreq MiB is required to run LiveKit/Retro."
	        echo "The LiveKit environment has been disabled."
        else
		echo "Your system currently have $total_mem_rounded MiB of memory, but at least $memreq MiB is required to run the graphical environment."
	        echo "The graphical environment has been disabled."
        fi
        echo " "
        pause "Press any key to return to the main menu."
}

if [ $total_mem -gt 0 -a $total_mem -lt $memreq ] ; then
if [ "x$retro" = "x1" ] ; then
	menuentry 'LiveKit has detected that your system has insufficient memory' {
                err_lowmem
        }
        menuentry 'to run the LiveKit and has disabled the live environment.' {
                err_lowmem
        }
        set nocli=1
        set default=boot_default_os
else # retro = 1
	menuentry 'LiveKit has detected that your system has less than 2GiB of memory' {
		err_lowmem
	}
	menuentry 'and has disabled the graphical environment.' {
		err_lowmem
	}
	set nogui=1
	set default=livekit_cli
fi # retro = 1
	# Spacer
        menuentry ' ' {
                err_lowmem
        }
	# Give users time to look around
	set timeout=60
fi

if [ "x$nogui" = "x0" ] ; then
	menuentry 'LiveKit' --class aosc --class gnu-linux --class gnu --class os --id livekit_gui --unrestricted {
		linux /boot/kernel root=live:CDLABEL=LiveKit rd.live.check quiet splash
		initrd /boot/live-initramfs.img
	}
fi
if [ "x$nocli" = "x0" ] ; then
	menuentry "$cli_title" --class aosc --class gnu-linux --class gnu --class os --id livekit_cli --unrestricted {
		linux /boot/kernel root=live:CDLABEL=LiveKit rd.live.check quiet splash systemd.unit=multi-user.target
		initrd /boot/live-initramfs.img
	}
fi

if [ "$grub_platform" = "efi" ]; then
submenu 'Utilities >>' {
	menuentry 'Memory Test' {
		chainloader /boot/memtest.efi
	}
	menuentry 'UEFI Firmware Settings' --id 'uefi-firmware' {
		fwsetup
	}
}
else
submenu 'Utilities >>' {
	menuentry 'Memory Test' {
		linux16 /boot/memtest.bin
	}
}
fi

menuentry 'Boot Default OS' --id boot_default_os {
	exit 1
}

if [ "x$grub_platform" = "xpc" -o "x$grub_platform" = "xefi" ] ; then
	menuentry 'Restart' {
		reboot
	}
	menuentry 'Power Off' {
		halt
	}
fi
