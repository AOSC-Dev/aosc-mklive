#: installer.cfg:4 livekit.cfg:4
msgid "Install AOSC OS (Command-line Only)"
msgstr "安裝 AOSC OS（命令列模式）"

#: installer.cfg:7 installer.cfg:44 livekit.cfg:7 livekit.cfg:44
msgid "Install AOSC OS"
msgstr "安裝 AOSC OS"

#: installer.cfg:9 livekit.cfg:9
msgid "Install AOSC OS (Serial Console)"
msgstr "安裝 AOSC OS（序列埠終端）"

#: installer.cfg:14 livekit.cfg:14
#, sh-format
msgid ""
"Your system currently have $memsize MiB of memory, but at least $memreq MiB "
"is required to run LiveKit/Retro."
msgstr ""
"您的裝置目前擁有 $memsize MiB 記憶體，不足以執行 LiveKit/Retro。執行 LiveKit/"
"Retro 需要至少 $memreq MiB 的記憶體。"

#: installer.cfg:15 livekit.cfg:15
msgid "The requirement is not fullfilled, thus LiveKit has been disabled.."
msgstr "未滿足記憶體需求，無法使用 LiveKit 環境。LiveKit 環境已被禁用。"

#: installer.cfg:17 livekit.cfg:17
#, sh-format
msgid ""
"Your system currently have $memsize MiB of memory, but at least $memreq MiB "
"is required to run the graphical environment."
msgstr ""
"您的裝置當前可用記憶體為 $memsize MiB，不足以執行圖形化安裝環境。執行圖形化安"
"裝環境需要至少 $memreq MiB 記憶體。"

#: installer.cfg:18 livekit.cfg:18
msgid "The graphical environment has been disabled."
msgstr "由於記憶體不足，圖形化安裝環境已被禁用。"

#: installer.cfg:21 livekit.cfg:21
msgid "Press any key to return to the main menu."
msgstr "請按任意鍵返回主選單。"

#: installer.cfg:26 livekit.cfg:26
msgid "LiveKit has detected that your system has insufficient memory"
msgstr "LiveKit 偵測到您的裝置可用記憶體不足以執行 LiveKit 的"

#: installer.cfg:30 livekit.cfg:30
msgid "to run the LiveKit and has disabled the live environment."
msgstr "安裝環境，因此您無法使用 LiveKit。"

#: installer.cfg:34 livekit.cfg:34
msgid "and has disabled the graphical environment."
msgstr "圖形化安裝環境，因此您無法使用圖形化安裝程式。"

#: installer.cfg:50
msgid "Graphics options for AOSC OS installation >>"
msgstr "安裝 AOSC OS 的其他圖形選項 >>"

#: installer.cfg:54
msgid "Try AOSC OS Desktop"
msgstr "試用 AOSC OS 桌面版"

#: installer.cfg:60
msgid "Graphics options for AOSC OS Desktop >>"
msgstr "試用 AOSC OS 的其他圖形選項 >>"

#: installer.cfg:82
msgid "Troubleshooting Options >>"
msgstr "故障排除選項 >>"

#: installer.cfg:83 livekit.cfg:50
msgid "Install AOSC OS (Basic graphics)"
msgstr "安裝 AOSC OS（基本圖形）"

#: installer.cfg:95 installer.cfg:113 livekit.cfg:75 livekit.cfg:93
msgid "Utilities >>"
msgstr "實用工具 >>"

#: installer.cfg:97 installer.cfg:114 livekit.cfg:77 livekit.cfg:94
msgid "Memory Test"
msgstr "記憶體測試工具"

#: installer.cfg:106 livekit.cfg:86
msgid "UEFI Firmware Settings"
msgstr "UEFI 韌體設定"

#: installer.cfg:121 livekit.cfg:101
msgid "Boot Default OS"
msgstr "啟動預設系統"

#: installer.cfg:126 livekit.cfg:106
msgid "Restart"
msgstr "重新啟動"

#: installer.cfg:129 livekit.cfg:109
msgid "Power Off"
msgstr "關機"

