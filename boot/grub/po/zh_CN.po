msgstr "安装 AOSC OS（兆芯 C-1080/1190 集成显卡）"

#: installer-livekit-gpus.cfg:26
msgid "Install AOSC OS (integrated Zhaoxin C-960 GPUs)"
msgstr "安装 AOSC OS（兆芯 C-960 集成显卡）"

#: installer-desktop-gpus.cfg:3
msgid "Try AOSC OS Desktop (NVIDIA GPUs)"
msgstr "试用 AOSC OS 桌面版（NVIDIA 显卡）"

#: installer-desktop-gpus.cfg:8
msgid "Try AOSC OS Desktop (NVIDIA GPUs older than GeForce GTX 16 series)"
msgstr "试用 AOSC OS 桌面版（NVIDIA GeForce GTX 16 以下系列显卡）"

#: installer-desktop-gpus.cfg:15
msgid "Try AOSC OS Desktop Desktop (Glenfly Arise 1000/2000 series GPUs)"
msgstr "试用 AOSC OS 桌面版（格兰菲 Arise 1000/2000 系列显卡）"

#: installer-desktop-gpus.cfg:22
msgid "Try AOSC OS Desktop (integrated Zhaoxin C-1080/1190 GPUs)"
msgstr "试用 AOSC OS 桌面版（兆芯 C-1080/1190 集成显卡）"

#: installer-desktop-gpus.cfg:27
msgid "Try AOSC OS Desktop (integrated Zhaoxin C-960 GPUs)"
